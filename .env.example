# ZelaznaCRM – przykładowy plik zmiennych środowiskowych
# Skopiuj do .env i uzupełnij prawdziwymi wartościami.
# UWAGA: Plik .env NIE może trafić do repozytorium!

# -------------------------------------------------------------------------
# Django
# -------------------------------------------------------------------------
SECRET_KEY=wygeneruj-unikalny-klucz-django-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# -------------------------------------------------------------------------
# Baza danych
# Development: sqlite:///db.sqlite3
# Production:  postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
# -------------------------------------------------------------------------
DATABASE_URL=sqlite:///db.sqlite3

# -------------------------------------------------------------------------
# Email (produkcja)
# -------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=twoj@email.pl
EMAIL_HOST_PASSWORD=twoje-haslo-app
DEFAULT_FROM_EMAIL=noreply@zelaznaCRM.pl

# -------------------------------------------------------------------------
# CEIDG API (dane.biznes.gov.pl) — autouzupełnianie NIP
# Zostaw puste aby używać fallbacku Białej Listy MF (bezpłatny, bez tokenu)
# Token uzyskasz po rejestracji na: https://dane.biznes.gov.pl
# -------------------------------------------------------------------------
CEIDG_API_TOKEN=
